{
  "name": "@forge/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --reporter=verbose src/**/*.test.ts",
    "test:integration": "vitest run --reporter=verbose --config vitest.integration.config.ts",
    "test:bdd": "cucumber-js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env.local src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env.local src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist coverage reports"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@forge/shared": "workspace:*",
    "bullmq": "^5.12.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "openid-client": "^5.7.0",
    "postgres": "^3.4.4",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "stripe": "^16.5.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.4",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.8.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.4"
  }
}
