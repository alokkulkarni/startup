{
  "name": "@forge/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --reporter=verbose src/**/*.test.ts",
    "test:integration": "vitest run --reporter=verbose --config vitest.integration.config.ts",
    "test:bdd": "cucumber-js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist coverage reports"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-kms": "^3.1007.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/credential-providers": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@fastify/websocket": "^8.3.1",
    "@forge/shared": "workspace:*",
    "@octokit/rest": "^22.0.1",
    "@octokit/types": "^16.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "diff": "^5.2.0",
    "dockerode": "^4.0.4",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "lib0": "^0.2.117",
    "openid-client": "^5.7.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "postgres": "^3.4.4",
    "stripe": "^16.5.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/diff": "^5.2.1",
    "@types/dockerode": "^3.3.31",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.0.4",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.8.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.4"
  }
}
