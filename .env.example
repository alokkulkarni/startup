# Forge AI — Environment Variables
# Copy this to .env.local and fill in values for local dev

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgres://forge:forge@localhost:5432/forge

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO ───────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_ASSETS=assets

# ─── Keycloak ────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=forge
KEYCLOAK_CLIENT_ID=forge-api
KEYCLOAK_CLIENT_SECRET=forge-api-secret

# ─── Next.js public env ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
NEXT_PUBLIC_KEYCLOAK_REALM=forge
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=forge-web

# ─── AI Providers ────────────────────────────────────────────────
# AWS Bedrock (primary AI provider — uses IAM role assumption, NOT static keys)
#
# PRODUCTION (EC2 / ECS / EKS):
#   Attach ForgeAIBedrockRole as the instance/task/pod role — no vars needed.
#
# CROSS-ACCOUNT / EXPLICIT ROLE ASSUMPTION:
#   Set AWS_ROLE_ARN — the SDK will call sts:AssumeRole automatically.
#   Base credentials come from the instance role or AWS_PROFILE.
#
# LOCAL DEV — Option 1: named AWS profile (recommended, no plaintext keys)
#   AWS_PROFILE=forge-dev  (configure in ~/.aws/config)
#
# LOCAL DEV — Option 2: static credentials (developer IAM user only, never commit)
#   AWS_ACCESS_KEY_ID=AKIA...
#   AWS_SECRET_ACCESS_KEY=...
#
# See infra/aws/README.md for full setup instructions and IAM policy.
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/ForgeAIBedrockRole
AWS_ROLE_SESSION_NAME=forge-bedrock-session
# AWS_PROFILE=forge-dev                    # alternative: use named AWS profile
# AWS_ACCESS_KEY_ID=                       # local dev fallback only — never commit
# AWS_SECRET_ACCESS_KEY=                   # local dev fallback only — never commit
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Email ───────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@forge.local

# ─── Deployment ──────────────────────────────────────────────────
FORGE_VERCEL_API_KEY=
FORGE_NETLIFY_API_KEY=
FORGE_CF_API_TOKEN=
FORGE_CF_ACCOUNT_ID=
FORGE_ENCRYPTION_KEY=change-me-use-32-char-random-string

# ─── GitHub App #1 — Forge Code Integration ───────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Homepage URL:    http://localhost
# Callback URL:    http://localhost/api/v1/github/callback
GITHUB_CLIENT_ID=your-forge-github-app-client-id
GITHUB_CLIENT_SECRET=your-forge-github-app-client-secret

# ─── GitHub App #2 — Keycloak Social Login (sign in with GitHub) ──────────────
# Create a SEPARATE OAuth App at: https://github.com/settings/developers
# Homepage URL:    http://localhost
# Callback URL:    http://localhost:8081/realms/forge/broker/github/endpoint
GITHUB_KC_CLIENT_ID=your-keycloak-github-app-client-id
GITHUB_KC_CLIENT_SECRET=your-keycloak-github-app-client-secret

# ─── Google OAuth (for Keycloak social login) ──────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8081/realms/forge/broker/google/endpoint
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
